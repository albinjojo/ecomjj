generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id              BigInt    @id @default(autoincrement())
  name            String    @db.VarChar
  slug            String    @unique @db.VarChar
  isActive        Boolean   @default(true) @map("is_active")
  imageUrl        String?   @map("image_url")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  requiresPacking Boolean   @default(false) @map("requires_packing")
  products        Product[]

  @@map("categories")
}

model User {
  id         BigInt             @id @default(autoincrement())
  name       String             @db.VarChar
  phone      String?            @db.VarChar
  email      String             @unique @db.VarChar
  authUserId String             @unique @map("auth_user_id") @db.VarChar
  isActive   Boolean            @default(true) @map("is_active")
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  addresses  Address[]
  carts      Cart[]
  orders     Order[]
  pushSubs   PushSubscription[]

  @@map("users")
}

model Admin {
  id               BigInt                  @id @default(autoincrement())
  username         String                  @unique @db.VarChar
  email            String                  @unique @db.VarChar
  passwordHash     String                  @map("password_hash")
  name             String                  @db.VarChar
  isActive         Boolean                 @default(true) @map("is_active")
  resetToken       String?                 @map("reset_token")
  resetTokenExpiry DateTime?               @map("reset_token_expiry") @db.Timestamptz(6)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  pushSubs         AdminPushSubscription[]

  @@map("admins")
}

model Product {
  id           BigInt           @id @default(autoincrement())
  categoryId   BigInt           @map("category_id")
  name         String           @db.VarChar
  description  String?
  thumbnailUrl String?          @map("thumbnail_url")
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  slug         String           @unique @db.VarChar
  isFeatured   Boolean          @default(false) @map("is_featured")
  images       ProductImage[]
  variants     ProductVariant[]
  category     Category         @relation(fields: [categoryId], references: [id])

  @@map("products")
}

model Address {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @map("user_id")
  name          String   @db.VarChar
  phone         String   @db.VarChar
  houseName     String   @map("house_name") @db.VarChar
  street        String   @db.VarChar
  city          String   @db.VarChar
  postcode      String   @db.VarChar
  landmark      String?  @db.VarChar
  deliveryNotes String?  @map("delivery_notes")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User     @relation(fields: [userId], references: [id])
  orders        Order[]

  @@map("addresses")
}

model ProductVariant {
  id             BigInt      @id @default(autoincrement())
  productId      BigInt      @map("product_id")
  variantName    String      @map("variant_name") @db.VarChar
  price          Decimal     @db.Decimal(10, 2)
  offerPrice     Decimal?    @map("offer_price") @db.Decimal(10, 2)
  offerEnabled   Boolean     @default(false) @map("offer_enabled")
  offerStartDate DateTime?   @map("offer_start_date") @db.Timestamptz(6)
  offerEndDate   DateTime?   @map("offer_end_date") @db.Timestamptz(6)
  stock          Int         @default(0)
  sku            String?     @db.VarChar
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  cartItems      CartItem[]
  orderItems     OrderItem[]
  // Variants have no independent purpose once their product is gone, so delete them with it.
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model ProductImage {
  id           BigInt   @id @default(autoincrement())
  productId    BigInt   @map("product_id")
  imageUrl     String   @map("image_url")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  // Images have no independent purpose once their product is gone, so delete them with it.
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Cart {
  id        BigInt     @id @default(autoincrement())
  userId    BigInt     @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id])

  @@map("carts")
}

model CartItem {
  id               BigInt         @id @default(autoincrement())
  cartId           BigInt         @map("cart_id")
  productVariantId BigInt         @map("product_variant_id")
  quantity         Int            @default(1)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart             Cart           @relation(fields: [cartId], references: [id])
  // Carts are ephemeral/local, so a cart item can just disappear when its variant is deleted.
  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model DeliveryPostcode {
  id             BigInt   @id @default(autoincrement())
  postcode       String   @unique @db.VarChar
  deliveryCharge Decimal  @map("delivery_charge") @db.Decimal(10, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("delivery_postcodes")
}

model Banner {
  id           BigInt   @id @default(autoincrement())
  title        String   @db.VarChar
  imageUrl     String   @map("image_url")
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("banners")
}

model Order {
  id             BigInt        @id @default(autoincrement())
  userId         BigInt        @map("user_id")
  addressId      BigInt        @map("address_id")
  orderNumber    String        @unique @map("order_number") @db.VarChar
  subtotal       Decimal       @db.Decimal(10, 2)
  deliveryCharge Decimal       @map("delivery_charge") @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  grandTotal     Decimal       @map("grand_total") @db.Decimal(10, 2)
  paymentMethod  PaymentMethod @map("payment_method")
  paymentStatus  PaymentStatus @map("payment_status")
  orderStatus    OrderStatus   @map("order_status")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  packingCharge  Decimal       @default(0) @map("packing_charge") @db.Decimal(10, 2)
  items          OrderItem[]
  address        Address       @relation(fields: [addressId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id               BigInt          @id @default(autoincrement())
  orderId          BigInt          @map("order_id")
  productId        BigInt?         @map("product_id")
  productVariantId BigInt?         @map("product_variant_id")
  productName      String          @map("product_name") @db.VarChar
  variantName      String          @map("variant_name") @db.VarChar
  price            Decimal         @db.Decimal(10, 2)
  quantity         Int
  total            Decimal         @db.Decimal(10, 2)
  order            Order           @relation(fields: [orderId], references: [id])
  // OrderItem already stores a permanent snapshot (productName, variantName, price) independent of
  // live product data, so a deleted variant should only clear the link here, never delete the order record.
  variant          ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model PushSubscription {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id])

  @@map("push_subscriptions")
}

model Settings {
  id                    BigInt   @id @default(autoincrement())
  deliveryChargeEnabled Boolean  @default(false) @map("delivery_charge_enabled")
  deliveryChargeAmount  Decimal  @default(0) @map("delivery_charge_amount") @db.Decimal(10, 2)
  packingChargeEnabled  Boolean  @default(false) @map("packing_charge_enabled")
  packingChargeAmount   Decimal  @default(0) @map("packing_charge_amount") @db.Decimal(10, 2)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("settings")
}

model AdminPushSubscription {
  id        BigInt   @id @default(autoincrement())
  adminId   BigInt   @map("admin_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  admin     Admin    @relation(fields: [adminId], references: [id])

  @@map("admin_push_subscriptions")
}

enum PaymentMethod {
  COD
  CARD
  ONLINE

  @@map("payment_method_enum")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED

  @@map("payment_status_enum")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED

  @@map("order_status_enum")
}
