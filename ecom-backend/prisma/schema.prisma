generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PaymentMethod {
  COD
  CARD
  ONLINE

  @@map("payment_method_enum")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED

  @@map("payment_status_enum")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED

  @@map("order_status_enum")
}

model Category {
  id              BigInt    @id @default(autoincrement())
  name            String    @db.VarChar
  slug            String    @db.VarChar @unique
  isActive        Boolean   @default(true) @map("is_active")
  requiresPacking Boolean   @default(false) @map("requires_packing")
  imageUrl        String?   @map("image_url")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  products        Product[]

  @@map("categories")
}

model User {
  id         BigInt   @id @default(autoincrement())
  name       String   @db.VarChar
  phone      String?  @db.VarChar
  email      String   @db.VarChar @unique
  authUserId String   @map("auth_user_id") @db.VarChar @unique
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  addresses Address[]
  carts     Cart[]
  orders    Order[]
  pushSubs  PushSubscription[]

  @@map("users")
}

model Admin {
  id               BigInt    @id @default(autoincrement())
  username         String    @db.VarChar @unique
  email            String    @db.VarChar @unique
  passwordHash     String    @map("password_hash") @db.Text
  name             String    @db.VarChar
  isActive         Boolean   @default(true) @map("is_active")
  resetToken       String?   @map("reset_token") @db.Text
  resetTokenExpiry DateTime? @map("reset_token_expiry") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  pushSubs AdminPushSubscription[]

  @@map("admins")
}

model Product {
  id           BigInt   @id @default(autoincrement())
  categoryId   BigInt   @map("category_id")
  name         String   @db.VarChar
  slug         String   @db.VarChar @unique
  description  String?  @db.Text
  thumbnailUrl String?  @map("thumbnail_url") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  isFeatured   Boolean  @default(false) @map("is_featured")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  images   ProductImage[]

  @@map("products")
}

model Address {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @map("user_id")
  name          String   @db.VarChar
  phone         String   @db.VarChar
  houseName     String   @map("house_name") @db.VarChar
  street        String   @db.VarChar
  city          String   @db.VarChar
  postcode      String   @db.VarChar
  landmark      String?  @db.VarChar
  deliveryNotes String?  @map("delivery_notes") @db.Text
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@map("addresses")
}

model ProductVariant {
  id             BigInt    @id @default(autoincrement())
  productId      BigInt    @map("product_id")
  variantName    String    @map("variant_name") @db.VarChar
  price          Decimal   @db.Decimal(10, 2)
  offerPrice     Decimal?  @map("offer_price") @db.Decimal(10, 2)
  offerEnabled   Boolean   @default(false) @map("offer_enabled")
  offerStartDate DateTime? @map("offer_start_date") @db.Timestamptz
  offerEndDate   DateTime? @map("offer_end_date") @db.Timestamptz
  stock          Int       @default(0)
  sku            String?   @db.VarChar
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  product    Product     @relation(fields: [productId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

model ProductImage {
  id           BigInt   @id @default(autoincrement())
  productId    BigInt   @map("product_id")
  imageUrl     String   @map("image_url") @db.Text
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id])

  @@map("product_images")
}

model Cart {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id               BigInt   @id @default(autoincrement())
  cartId           BigInt   @map("cart_id")
  productVariantId BigInt   @map("product_variant_id")
  quantity         Int      @default(1)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  cart    Cart           @relation(fields: [cartId], references: [id])
  variant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@map("cart_items")
}

model DeliveryPostcode {
  id             BigInt   @id @default(autoincrement())
  postcode       String   @db.VarChar @unique
  deliveryCharge Decimal  @map("delivery_charge") @db.Decimal(10, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("delivery_postcodes")
}

model Banner {
  id           BigInt   @id @default(autoincrement())
  title        String   @db.VarChar
  imageUrl     String   @map("image_url") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("banners")
}

model Order {
  id             BigInt        @id @default(autoincrement())
  userId         BigInt        @map("user_id")
  addressId      BigInt        @map("address_id")
  orderNumber    String        @map("order_number") @db.VarChar @unique
  subtotal       Decimal       @db.Decimal(10, 2)
  deliveryCharge Decimal       @map("delivery_charge") @db.Decimal(10, 2)
  packingCharge  Decimal       @default(0) @map("packing_charge") @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  grandTotal     Decimal       @map("grand_total") @db.Decimal(10, 2)
  paymentMethod  PaymentMethod @map("payment_method")
  paymentStatus  PaymentStatus @map("payment_status")
  orderStatus    OrderStatus   @map("order_status")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user    User        @relation(fields: [userId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])
  items   OrderItem[]

  @@map("orders")
}

model OrderItem {
  id               BigInt          @id @default(autoincrement())
  orderId          BigInt          @map("order_id")
  productId        BigInt?         @map("product_id")
  productVariantId BigInt?         @map("product_variant_id")
  productName      String          @map("product_name") @db.VarChar
  variantName      String          @map("variant_name") @db.VarChar
  price            Decimal         @db.Decimal(10, 2)
  quantity         Int
  total            Decimal         @db.Decimal(10, 2)

  order   Order           @relation(fields: [orderId], references: [id])
  variant ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@map("order_items")
}

model PushSubscription {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("push_subscriptions")
}

model Settings {
  id                    BigInt   @id @default(autoincrement())
  deliveryChargeEnabled Boolean  @default(false) @map("delivery_charge_enabled")
  deliveryChargeAmount  Decimal  @default(0) @map("delivery_charge_amount") @db.Decimal(10, 2)
  packingChargeEnabled  Boolean  @default(false) @map("packing_charge_enabled")
  packingChargeAmount   Decimal  @default(0) @map("packing_charge_amount") @db.Decimal(10, 2)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("settings")
}

model AdminPushSubscription {
  id        BigInt   @id @default(autoincrement())
  adminId   BigInt   @map("admin_id")
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  admin Admin @relation(fields: [adminId], references: [id])

  @@map("admin_push_subscriptions")
}
